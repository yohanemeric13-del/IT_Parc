<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gestion_alerte_tree" model="ir.ui.view">
        <field name="name">gestion.alerte.list</field>
        <field name="model">gestion.alerte</field>
        <field name="arch" type="xml">
            <list string="Notifications">
                <field name="name"/>
                <field name="alert_type"/>
                <field name="severity"/>
                <field name="equipment_id"/>
                <field name="contract_id"/>
                <field name="date_deadline"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gestion_alerte_form" model="ir.ui.view">
        <field name="name">gestion.alerte.form</field>
        <field name="model">gestion.alerte</field>
        <field name="arch" type="xml">
            <form string="Notification">
                <header>
                    <button name="action_done" string="Traiter" type="object" class="btn-primary" invisible="state != 'open'"/>
                    <button name="action_cancel" string="Annuler" type="object" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="alert_type"/>
                            <field name="severity"/>
                            <field name="date_deadline"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="contract_id"/>
                        </group>
                    </group>
                    <field name="message"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gestion_alerte" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">gestion.alerte</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
