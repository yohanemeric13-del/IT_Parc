<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gestion_intervention_tree" model="ir.ui.view">
        <field name="name">gestion.intervention.list</field>
        <field name="model">gestion.intervention</field>
        <field name="arch" type="xml">
            <list string="Maintenances">
                <field name="name"/>
                <field name="parc_equipment_id"/>
                <field name="intervention_type"/>
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="duration_hours"/>
                <field name="cost"/>
            </list>
        </field>
    </record>

    <record id="view_gestion_intervention_calendar" model="ir.ui.view">
        <field name="name">gestion.intervention.calendar</field>
        <field name="model">gestion.intervention</field>
        <field name="arch" type="xml">
            <calendar string="Planning interventions" date_start="date_start" date_stop="date_end" color="user_id">
                <field name="name"/>
                <field name="parc_equipment_id"/>
                <field name="intervention_type"/>
                <field name="user_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_gestion_intervention_form" model="ir.ui.view">
        <field name="name">gestion.intervention.form</field>
        <field name="model">gestion.intervention</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <header>
                    <button name="%(gestion_parc.action_report_it_maintenance_history)d" string="Historique PDF" type="action"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="parc_equipment_id"/>
                            <field name="intervention_type"/>
                            <field name="user_id"/>
                            <field name="maintenance_team_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="duration_hours"/>
                            <field name="cost"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rapport">
                            <field name="intervention_report"/>
                        </page>
                        <page string="Maintenance Odoo">
                            <group>
                                <field name="stage_id"/>
                                <field name="priority"/>
                                <field name="schedule_date"/>
                                <field name="description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gestion_intervention" model="ir.actions.act_window">
        <field name="name">Maintenances</field>
        <field name="res_model">gestion.intervention</field>
        <field name="view_mode">list,form,calendar</field>
    </record>
</odoo>
