<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_renouvellement_accord_wizard_form" model="ir.ui.view">
        <field name="name">gestion.renouvellement.accord.wizard.form</field>
        <field name="model">gestion.renouvellement.accord.wizard</field>
        <field name="arch" type="xml">
            <form string="Renouveler un accord">
                <group>
                    <field name="contract_id"/>
                    <field name="old_date_end"/>
                    <field name="new_date_start"/>
                    <field name="new_date_end"/>
                    <field name="new_amount"/>
                    <field name="currency_id"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_renew" string="Renouveler" type="object" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_renouvellement_accord_wizard" model="ir.actions.act_window">
        <field name="name">Renouveler un accord</field>
        <field name="res_model">gestion.renouvellement.accord.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
