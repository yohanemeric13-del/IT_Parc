<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_import_csv_wizard_form" model="ir.ui.view">
        <field name="name">gestion.import.csv.wizard.form</field>
        <field name="model">gestion.import.csv.wizard</field>
        <field name="arch" type="xml">
            <form string="Importer un inventaire CSV">
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="delimiter"/>
                    <field name="result" readonly="1" invisible="not result"/>
                </group>
                <footer>
                    <button name="action_import" string="Importer" type="object" class="btn-primary"/>
                    <button string="Fermer" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_import_csv_wizard" model="ir.actions.act_window">
        <field name="name">Importer CSV</field>
        <field name="res_model">gestion.import.csv.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
