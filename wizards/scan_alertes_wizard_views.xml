<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_scan_alertes_wizard_form" model="ir.ui.view">
        <field name="name">gestion.scan.alertes.wizard.form</field>
        <field name="model">gestion.scan.alertes.wizard</field>
        <field name="arch" type="xml">
            <form string="Scanner les alertes">
                <group>
                    <field name="scan_warranties"/>
                    <field name="warranty_delay_days" invisible="not scan_warranties"/>
                    <field name="scan_contracts"/>
                    <field name="contract_delay_days" invisible="not scan_contracts"/>
                </group>
                <footer>
                    <button name="action_scan" string="Scanner" type="object" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_it_scan_alertes_wizard" model="ir.actions.act_window">
        <field name="name">Scanner les alertes</field>
        <field name="res_model">gestion.scan.alertes.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
